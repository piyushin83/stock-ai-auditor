# ─────────────────────────────────────────────────────────
#  RENAME THIS FILE TO .env  (never commit .env to GitHub)
#  Add .env to your .gitignore file immediately
# ─────────────────────────────────────────────────────────

# App login password (used by auth.py)
APP_PASSWORD=your_strong_password_here

# Optional: comma-separated list of allowed usernames
# APP_USERS=alice,bob,charlie

# Optional: secret key for session tokens (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=replace_with_random_64_char_hex_string

# Add any API keys here instead of hardcoding in app.py
# FINVIZ_API_KEY=
# OPENAI_API_KEY=
